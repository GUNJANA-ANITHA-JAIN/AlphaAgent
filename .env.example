# Copy this file to `.env` in the same directory and set real values.
# `.env` is gitignored — do not paste tokens into the repo or chat.

# Hugging Face read token (FinBERT / Hub downloads)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: log every MarketEvent at INFO when using run_pipeline.py
# ALPHAGENT_LOG_EVENTS=1

# Optional: INFO logs from technical / macro / fundamental (why RSI period, VIX, keywords)
# ALPHAGENT_DEBUG_AGENTS=1

# Optional: FRED API key — treasury yield-curve context (default series T10Y2Y = 10Y minus 2Y spread)
# https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=
# ALPHAGENT_FRED_SERIES_ID=T10Y2Y

# Fusion tuning (orchestrator weighted mean → BUY/SELL/HOLD)
# ALPHAGENT_HOLD_DEADBAND=0.075
# ALPHAGENT_FUSION_NEUTRAL_SCORE_ABS=0.032
# ALPHAGENT_FUSION_NEUTRAL_WEIGHT_MULT=0.38
# ALPHAGENT_FUSION_AGREEMENT_BOOST=0.030
# Cap toy / execution sizing hook (see fuse_signals position_weight)
# ALPHAGENT_FUSION_POSITION_CAP=0.58
# Low floor for 2-agent backtests only — keep small to avoid oversized toy PnL
# ALPHAGENT_FUSION_CONF_FLOOR=0.22

# Technical: MA regime + RSI (default ON). Set 0 for legacy RSI+momentum blend only.
# ALPHAGENT_TECH_REGIME_FILTER=1
# ALPHAGENT_TECH_MA_PERIOD=200
# ALPHAGENT_TECH_MA_MIN_BARS=20
# ALPHAGENT_TECH_REGIME_BAND=0.004
# Trending (up/down) vs sideways factor weights in alpha engine — momentum vs mean-reversion (default 1).
# ALPHAGENT_TECH_REGIME_SWITCH=0
# ALPHAGENT_TECH_CLOSE_BUFFER=260
# Uptrend exhaustion SELL: RSI above threshold AND mom<0 (see technical_agent.py)
# ALPHAGENT_TECH_UPTREND_EXHAUST_RSI=76
# ALPHAGENT_TECH_UPTREND_SOFT_SELL_RSI=68
# ALPHAGENT_TECH_UPTREND_SOFT_SELL_MOM=-0.02
# ALPHAGENT_TECH_UPTREND_STRETCH_RSI_LONE=70
# ALPHAGENT_TECH_UPTREND_HOLD_TILT=1
# ALPHAGENT_TECH_UPTREND_SELL_REQUIRE_VOL=0
# Technical: default continuous alpha (dispersion). Set 0 for discrete rules only.
# ALPHAGENT_TECH_ALPHA_ENGINE=1
# Optional scales for factor normalization (see technical_agent._alpha_features)
# ALPHAGENT_TECH_ALPHA_TREND_SCALE=0.095
# ALPHAGENT_TECH_ALPHA_RSI_SCALE=26
# ALPHAGENT_TECH_ALPHA_MOM_GAIN=14
# Rolling z-score + IC blend (IC off by default; see technical_agent.py)
# ALPHAGENT_TECH_ZSCORE=1
# ALPHAGENT_TECH_Z_WINDOW=105
# ALPHAGENT_TECH_ORTHOGONALIZE=1
# ALPHAGENT_TECH_IC_BLEND=0
# ALPHAGENT_TECH_IC_HORIZON=5
# ALPHAGENT_TECH_IC_MIN_SAMPLES=55
# ALPHAGENT_TECH_IC_MAX_HISTORY=252
# ALPHAGENT_TECH_IC_BLEND_LAMBDA=0.20
# ALPHAGENT_TECH_IC_GAIN=0.18
# ALPHAGENT_TECH_IC_TILT=0.32
# ALPHAGENT_TECH_IC_SHRINK_ABS=0

# ALPHAGENT_FORM4_FETCH=1
# Pause (seconds) between SEC requests (Form 4 doc fetch). Either name works:
# ALPHAGENT_SEC_REQUEST_DELAY_SEC=0.12
# ALPHAGENT_FORM4_FETCH_DELAY_SEC=0.12

# Comma-separated tickers (default in run_pipeline.py is a 20-name basket for load testing)
# ALPHAGENT_TICKERS=AAPL,MSFT,GOOGL,AMZN,META

# Backtest (`python run_backtest.py` — price replay, see run_backtest.py header)
# ALPHAGENT_BACKTEST_TICKERS=AAPL,MSFT,GOOGL
# ALPHAGENT_BACKTEST_PERIOD=1y
# ALPHAGENT_BACKTEST_HORIZON=3
# ALPHAGENT_BACKTEST_OUTPUT=runs/backtest_last.md
# ALPHAGENT_BACKTEST_COST_BPS=5
# Toy PnL: `long_short` shorts on SELL — in equity walk-forwards with upward 5d drift, that leg
# often dominates a negative cumulative sum even when BUY timing is mediocre. Use `long_only`
# to attribute toy PnL to long legs only (see backtest report footnote).
# ALPHAGENT_BACKTEST_EXPOSURE=long_only
# ALPHAGENT_BACKTEST_EXPOSURE=long_short

# Cross-sectional L/S metrics in the markdown report (dollar-neutral book; does not change signals).
# ALPHAGENT_BACKTEST_BORROW_BPS=50
# ALPHAGENT_BACKTEST_LS_QUANTILE=0.25
# ALPHAGENT_BACKTEST_CS_MIN_NAMES=8

# Backtest: cross-sectional panel (default 1). Set 0 for legacy per-bar orchestrator path.
# ALPHAGENT_BACKTEST_CS_PANEL=1
# ALPHAGENT_BACKTEST_HORIZON=3
# Cross-section / short-horizon knobs (see orchestrator/cs_technical.py)
# ALPHAGENT_CS_BUY_FRAC=0.20
# ALPHAGENT_CS_SELL_FRAC=0.20
# ALPHAGENT_CS_VOL_Z=1.5
# ALPHAGENT_CS_TREND_DIST=0.08
# ALPHAGENT_CS_BASE_CONF=0.62

# Markdown run summary after each `python run_pipeline.py` (default: runs/latest_pipeline_run.md)
# ALPHAGENT_RUN_REPORT=1
# ALPHAGENT_RUN_REPORT_PATH=/absolute/path/to/my_run.md
